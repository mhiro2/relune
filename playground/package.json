{
  "name": "@relune/playground",
  "private": true,
  "description": "Public WASM playground for relune",
  "packageManager": "pnpm@10.32.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.14.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src",
    "lint": "oxlint src",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "check": "pnpm fmt:check && pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260331.1",
    "esbuild": "^0.27.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "~6.0.2"
  }
}
