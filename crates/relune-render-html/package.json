{
  "name": "@relune/render-html-scripts",
  "private": true,
  "description": "TypeScript sources for embedded HTML viewer scripts (build outputs to src/js/)",
  "packageManager": "pnpm@10.32.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.14.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "fmt": "oxfmt ts",
    "fmt:check": "oxfmt --check ts",
    "lint": "oxlint ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "check": "pnpm fmt:check && pnpm lint && pnpm typecheck"
  },
  "dependencies": {},
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260324.1",
    "esbuild": "^0.27.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "~6.0.2"
  },
  "minimumReleaseAge": 10080
}
