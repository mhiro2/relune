<svg xmlns="http://www.w3.org/2000/svg" width="12366" height="1910" viewBox="0 0 12366 1910" fill="none"><defs>
<style>
.edge-glow-path,
.edge-particles { opacity: 0; pointer-events: none; transition: opacity 0.18s ease; }
.edge-particle { fill: #fbbf24; }
.edge:hover .edge-glow-path,
.edge:hover .edge-particles { opacity: 0.92; }
.edge:hover .edge-path { stroke: #f59e0b; }
.node:hover .table-body { stroke-width: 2.1px; }
.group-box,
.group-band,
.group-divider,
.group-label { pointer-events: none; }
</style>
<pattern id="canvas-grid" width="32" height="32" patternUnits="userSpaceOnUse">
<rect width="32" height="32" fill="#0c0f1a"/>
<circle cx="2" cy="2" r="1.2" fill="#151928" fill-opacity="0.9"/>
<circle cx="18" cy="18" r="0.8" fill="#151928" fill-opacity="0.54"/>
</pattern>
<pattern id="type-filter-hatch" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(35)">
<rect width="8" height="8" fill="transparent"/>
<rect width="3" height="8" fill="#334155" fill-opacity="0.42"/>
</pattern>
<filter id="node-shadow" x="-20%" y="-20%" width="140%" height="150%">
<feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="rgba(0, 0, 0, 0.5)"/>
</filter>
<filter id="group-shadow" x="-20%" y="-20%" width="140%" height="160%">
<feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="rgba(0, 0, 0, 0.5)" flood-opacity="0.16"/>
</filter>
<filter id="edge-glow" x="-50%" y="-50%" width="200%" height="200%">
<feDropShadow dx="0" dy="0" stdDeviation="5" flood-color="#f59e0b"/>
</filter>
<marker id="arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
<path d="M0,0 L0,6 L9,3 z" fill="#64748b" />
</marker>
<marker id="cardinality-one" markerWidth="12" markerHeight="12" refX="10" refY="6" orient="auto-start-reverse" markerUnits="userSpaceOnUse">
<path d="M7 1 L7 11" stroke="#cbd5e1" stroke-width="1.8" stroke-linecap="round"/>
</marker>
<marker id="cardinality-many" markerWidth="12" markerHeight="12" refX="10" refY="6" orient="auto-start-reverse" markerUnits="userSpaceOnUse">
<path d="M1 1 L10 6 M1 6 L10 6 M1 11 L10 6" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</marker>
<marker id="cardinality-zero-many" markerWidth="16" markerHeight="12" refX="14" refY="6" orient="auto-start-reverse" markerUnits="userSpaceOnUse">
<circle cx="3.5" cy="6" r="2.2" fill="none" stroke="#cbd5e1" stroke-width="1.4"/>
<path d="M6 1 L14 6 M6 6 L14 6 M6 11 L14 6" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</marker>
