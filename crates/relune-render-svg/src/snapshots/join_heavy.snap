<svg xmlns="http://www.w3.org/2000/svg" width="12366" height="1910" viewBox="0 0 12366 1910" fill="none"><defs>
<pattern id="canvas-grid" width="32" height="32" patternUnits="userSpaceOnUse">
<rect width="32" height="32" fill="#0c0f1a"/>
<circle cx="2" cy="2" r="1.2" fill="#151928" fill-opacity="0.9"/>
</pattern>
<pattern id="type-filter-hatch" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(35)">
<rect width="8" height="8" fill="transparent"/>
<rect width="3" height="8" fill="#334155" fill-opacity="0.42"/>
</pattern>
<filter id="node-shadow" x="-20%" y="-20%" width="140%" height="150%">
<feDropShadow dx="0" dy="6" stdDeviation="8" flood-color="rgba(0, 0, 0, 0.52)"/>
</filter>
<filter id="edge-glow" x="-50%" y="-50%" width="200%" height="200%">
