</marker>
<marker id="cardinality-one" markerWidth="12" markerHeight="12" refX="10" refY="6" orient="auto-start-reverse" markerUnits="userSpaceOnUse">
<path d="M7 1 L7 11" stroke="#cbd5e1" stroke-width="1.8" stroke-linecap="round"/>
</marker>
