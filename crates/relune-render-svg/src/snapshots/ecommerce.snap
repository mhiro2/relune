</marker>
<marker id="cardinality-one" markerWidth="14" markerHeight="14" refX="12" refY="7" orient="auto-start-reverse" markerUnits="userSpaceOnUse">
<path d="M8 2 L8 12" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round"/>
</marker>
